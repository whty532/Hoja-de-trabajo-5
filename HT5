
import simpy
import random
import pandas as pd
import matplotlib.pyplot as plt
import statistics as st



RAM_TOTAL = 100
env = simpy.Environment()

RAM = simpy.Container(env, init = RAM_TOTAL, capacity = RAM_TOTAL)
CPU = simpy.Resource(env, capacity = 1)

def proceso(env, pid, RAM, CPU, cpu_speed, resultados):
    t0 = env.now

    mem = random.randint(1, 10)
    instr = random.randint(1, 10)

    yield RAM.get(mem)

    while instr > 0:
        with CPU.request() as request:
            yield request
            hechas = min(cpu_speed, instr)
            yield env.timeout(1)
            instr -= hechas
        
        if instr == 0:
            break

        r = random.randint(1, 21)
        if r == 1:
            yield env.timeout(1)
        
        yield RAM.put(mem)
        resultados.append(env.now - t0)

def generar_procesos(env, n, interval, RAM, CPU, cpu_speed, resultados):
    for i in range(n):
        env.process(proceso(env, i, RAM, CPU, cpu_speed, resultados))
        dt = random.expovariate(1.0/interval)
        yield env.timeout(dt)

def correr_simulacion(n_procesos, interval, ram_total=100, cpu_speed=3, cpus=1, seed=42):
    random.seed(seed)
    
    env = simpy.Environment()
    RAM = simpy.Container(env, init=ram_total, capacity=ram_total)
    CPU = simpy.Resource(env, capacity=cpus)
    resultados = []
    env.process(generar_procesos(env, n_procesos, interval, RAM, CPU, cpu_speed, resultados))
    env.run()
    return resultados

tiempos = correr_simulacion(25, interval=10)
print("promedios", st.mean(tiempos))
print("desviación estándar", st.stdev(tiempos))

datos = []
for n in {25, 50, 100, 150, 200}:
    tiempos = correr_simulacion(n, interval=10)
    datos.append({"n":n, "promedio":st.mean(tiempos), "desviación":st.stdev(tiempos)})

df = pd.DataFrame(datos)
print(df)

df.plot(x="n", y="promedio", kind="line", title="Promedio de tiempo de espera vs número de procesos")
plt.show()